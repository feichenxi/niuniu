# NPoker 环境配置模板
# 复制此文件为 .env 并填入真实值
# .env 文件不会被提交到 Git（已在 .gitignore 中排除）
#
# 提示：不需要配置任何内容即可运行！默认使用本地决策模式。

# 服务器域名配置
# 保持 localhost = 默认使用本地决策引擎（推荐，零配置）
# 填入真实域名 = 使用远程决策服务器
POKER_SERVER_DOMAIN=localhost

# 授权验证服务器地址（可选，未配置时以本地模式运行）
POKER_AUTH_URL=http://localhost/poker/user.php

# MySQL 数据库配置（可选）
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=poker

# HuggingFace 镜像（中国大陆用户可能需要）
HF_ENDPOINT=https://hf-mirror.com
